# Argus environment variables
# Copy to .env and fill in values as needed.

# Telemetry ingest endpoint (PostHog capture API or compatible).
# Leave blank to disable outbound telemetry entirely (useful for local dev).
# Example: https://app.posthog.com/capture/
TELEMETRY_URL=

# Note: TELEMETRY_API_KEY is a write-only PostHog project key hardcoded in
# backend/src/services/telemetry-service.ts by the maintainer at release time.
# It is intentionally public (PostHog project keys cannot read analytics data).
# End users do not need to configure it.
